# Secureframe API Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Secureframe API key
SECUREFRAME_API_KEY=your_api_key_here

# Required: Your Secureframe API secret  
SECUREFRAME_API_SECRET=your_api_secret_here

# Optional: API endpoint (defaults to https://api.secureframe.com)
# For UK region, use: https://api-uk.secureframe.com
SECUREFRAME_API_URL=https://api.secureframe.com

# Optional: set to true to disable all write operations (create/update/archive/delete).
# Leave unset (or false) to allow writes.
SECUREFRAME_READ_ONLY=false

# Optional: load credentials from an env file outside the repo, so secrets stay
# out of the project and any committed MCP config. Falls back to ./.env.
#   SECUREFRAME_ENV_FILE=/tmp/secureframe.env

# Optional: transport. "stdio" (default) for Claude Desktop/Cursor; "http" to
# expose the server over Streamable HTTP (required to consume it via the Claude
# API mcp_servers connector with deferred tool loading).
SECUREFRAME_MCP_TRANSPORT=stdio
SECUREFRAME_MCP_HOST=127.0.0.1
SECUREFRAME_MCP_PORT=8000

# Optional: shrink the exposed tool surface (and the tokens its definitions cost)
# by filtering on tags. Tags include each resource name plus "read"/"write".
# Comma-separated. Examples:
#   SECUREFRAME_EXCLUDE_TAGS=write          -> read-only server (writes removed)
#   SECUREFRAME_TOOL_TAGS=controls,tests    -> only controls and tests tools
SECUREFRAME_TOOL_TAGS=
SECUREFRAME_EXCLUDE_TAGS=